                            {
                                "type": "Integer",
                                "topicGet": "/devices/(1)/controls/Smart fan speed",
                                "topicSet": "/devices/(1)/controls/Smart fan speed/on",
                                "map": {
                                    "AUTO": 0,
                                    "LOW": 2,
                                    "MEDIUM": 3,
                                    "HIGH": 4
                                }
                            }
                        ],
                        "validValues": "AUTO,LOW,MEDIUM,HIGH"
                    },
                    {
                        "name": "Качание жалюзи",
