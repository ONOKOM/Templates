                        "link": [
                            {
                                "type": "Integer",
                                "topicGet": "/devices/(1)/controls/Target temperature",
                                "topicSet": "/devices/(1)/controls/Target temperature/on"
                            }
                        ],
                        "minValue": 16,
                        "maxValue": 30,
                        "minStep": 1
                    },
                    {
